# Depo Giriş Bilgileri
# Bu dosyayı kopyalayıp .env olarak kaydedin ve kendi bilgilerinizi girin

# Alliance Healthcare
ALLIANCE_ECZANE_KODU=
ALLIANCE_USERNAME=
ALLIANCE_PASSWORD=

# Selçuk Ecza
SELCUK_HESAP_KODU=
SELCUK_USERNAME=
SELCUK_PASSWORD=

# Yusuf Paşa
YUSUFPASA_ECZANE_KODU=
YUSUFPASA_USERNAME=
YUSUFPASA_PASSWORD=

# İstanbul Ecza Koop
ISKOOP_USERNAME=
ISKOOP_PASSWORD=

# Bursa Ecza Koop
BURSA_USERNAME=
BURSA_PASSWORD=

# Farmazon
FARMAZON_USERNAME=
FARMAZON_PASSWORD=

# Sancak Ecza
SANCAK_USERNAME=
SANCAK_PASSWORD=

# Eczane Bilgileri (WhatsApp mesajlarında görünecek)
ECZACI_ADI=
ECZANE_ADI=
ECZANE_TELEFONU=
ECZACI_TELEFONU=

# Tarayıcı Ayarları
HEADLESS=False
BROWSER=chrome

# Sipariş Ayarları
GUN_SAYISI=30
ALLIANCE_ENABLED=true
SELCUK_ENABLED=true
YUSUFPASA_ENABLED=true
ISKOOP_ENABLED=false
BURSA_ENABLED=false
FARMAZON_ENABLED=false
SANCAK_ENABLED=true
SHOW_PRICES=false

# MF (Mal Fazlası) Özelliği
# true = MF bilgilerini oku ve göster (daha yavaş)
# false = MF özelliğini kapat (daha hızlı)
MF_ENABLED=true

# Debug/Geliştirme Logları
# true = Tüm DEBUG ve INFO logları dosyaya yazılır (geliştirme için)
# false = Sadece WARNING ve ERROR logları dosyaya yazılır (daha hızlı)
DEBUG_LOGGING=false
